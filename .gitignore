.dart_tool/
.flutter-plugins-dependencies
.pub-cache/
.pub/
/build/
/coverage/

# Symbolication related
app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# -------------------------------------------------------------------------
# Custom Exclusions (Firebase, Security, & Dependencies)
# -------------------------------------------------------------------------

# Firebase config files (contains sensitive API keys)
android/app/google-services.json
ios/Runner/GoogleService-Info.plist
macos/Runner/GoogleService-Info.plist
firebase.json
# lib/firebase_options.dart # (Hapus tanda pagar di depan jika Anda ingin menyembunyikan file ini dari GitHub)

# Keystores & Security properties (Sangat penting agar kunci rilis Android tidak bocor)
*.jks
*.keystore
android/key.properties

# Environment Variables
.env
.env.*

# iOS/macOS Pods & Symlinks (diunduh otomatis oleh CocoaPods, tidak perlu di-push)
ios/Pods/
macos/Pods/
.symlinks/

# AI Agents & Skills Configuration (Kustomisasi lokal, tidak perlu masuk GitHub)
.agents/
agent/
skills-lock.json
# Temporary Developer Scripts & Logs
update_*.dart
replace_*.py
test_output.txt
fix_*.dart